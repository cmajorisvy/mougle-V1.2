# Mougle - Environment Variables
# Copy this file to .env and fill in your values

# ─── App Runtime ───
NODE_ENV=development
PORT=5000
APP_BASE_URL=https://www.mougle.com

# ─── Database (PostgreSQL) ───
# Required for app runtime and Drizzle commands:
# - npm run dev
# - npm start
# - npm run db:push
# Required Replit secret name: DATABASE_URL
DATABASE_URL=postgresql://username:password@hostname:5432/database_name

# Optional legacy split PG variables (not needed when DATABASE_URL is set)
# PGDATABASE=your_database_name
# PGHOST=your_database_host
# PGPORT=5432
# PGUSER=your_database_user
# PGPASSWORD=your_database_password

# ─── Authentication ───
# Required Replit secret name: SESSION_SECRET
SESSION_SECRET=your_random_session_secret_here

# ─── Admin Access ───
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=your_bcrypt_hashed_password_here

# ─── OpenAI (for AI features, debates, project pipeline) ───
AI_INTEGRATIONS_OPENAI_API_KEY=sk-your-openai-api-key
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Voice/TTS (optional, internal admin-review audio jobs) ───
# ElevenLabs is used first when configured. Replit/OpenAI audio is used as fallback
# when OPENAI_API_KEY or AI_INTEGRATIONS_OPENAI_API_KEY is configured.
# ELEVENLABS_API_KEY=your_elevenlabs_api_key
# ELEVENLABS_DEFAULT_VOICE_ID=your_default_elevenlabs_voice_id
# Optional per-agent overrides:
# VOXA_ELEVENLABS_VOICE_ID=your_voxa_voice_id
# MOUGLE_ELEVENLABS_VOICE_ID=your_mougle_voice_id

# ─── YouTube Publishing (optional, root-admin manual upload only) ───
# These are documented secret names only. Do not commit real values.
# YOUTUBE_CLIENT_ID=your_youtube_oauth_client_id
# YOUTUBE_CLIENT_SECRET=your_youtube_oauth_client_secret
# YOUTUBE_REFRESH_TOKEN=your_youtube_oauth_refresh_token
# YOUTUBE_CHANNEL_ID=your_youtube_channel_id

# ─── Social Distribution (optional, root-admin gated; names only) ───
# Dry-run/export mode is used by default when these are missing.
# X_API_KEY=your_x_api_key
# X_ACCESS_TOKEN=your_x_access_token
# TWITTER_BEARER_TOKEN=your_twitter_bearer_token
# LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
# FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token
# BLUESKY_IDENTIFIER=your_bluesky_identifier
# BLUESKY_APP_PASSWORD=your_bluesky_app_password

# ─── Content Flywheel ───
ENABLE_FLYWHEEL_VIDEO=false

# ─── Resend (for email delivery) ───
# Configured via Replit integration - add your Resend API key if running outside Replit
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@mougle.com

# ─── Replit-specific (auto-populated on Replit) ───
REPL_ID=auto_populated
REPLIT_DOMAINS=auto_populated
REPLIT_DEV_DOMAIN=auto_populated
