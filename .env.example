# Mougle V1.2 — Environment Variable Names Only
# Copy to `.env` and fill with local values (never commit secrets).

# App runtime
NODE_ENV=
PORT=
APP_BASE_URL=

# Database
DATABASE_URL=
PGDATABASE=
PGHOST=
PGPORT=
PGUSER=
PGPASSWORD=

# Auth/session
SESSION_SECRET=

# Admin access
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=

# AI providers
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=
OPENAI_API_KEY=

# Voice/TTS providers
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
VOXA_ELEVENLABS_VOICE_ID=
MOUGLE_ELEVENLABS_VOICE_ID=

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# YouTube (manual/admin-gated only)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# Social distribution (manual/admin-gated only)
X_API_KEY=
X_ACCESS_TOKEN=
TWITTER_BEARER_TOKEN=
LINKEDIN_ACCESS_TOKEN=
FACEBOOK_PAGE_ACCESS_TOKEN=
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=

# Feature toggles/runtime switches
ENABLE_FLYWHEEL_VIDEO=
UNREAL_BRIDGE_MODE=

# Replit runtime metadata (auto-populated on Replit)
REPL_ID=
REPLIT_DOMAINS=
REPLIT_DEV_DOMAIN=
